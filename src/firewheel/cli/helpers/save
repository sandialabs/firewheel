#!/usr/bin/env python
import argparse
import base64
import json
import math
import pickle
import shutil
import sys
from datetime import datetime, UTC
from pathlib import Path
from typing import Any

import minimega
from rich.console import Console
from rich.progress import (
    Progress,
    BarColumn,
    TextColumn,
    MofNCompleteColumn,
    TimeRemainingColumn,
)

from firewheel.config import config
from firewheel.cli.utils import cli_output_theme
from firewheel.lib.minimega.api import minimegaAPI
from firewheel.control.image_store import ImageStore
from firewheel.lib.minimega.file_store import FileStore
import firewheel.vm_resource_manager.api as vm_resource_api
from firewheel.vm_resource_manager.vm_mapping import VMMapping
from firewheel.vm_resource_manager.schedule_db import ScheduleDb
from firewheel.vm_resource_manager.schedule_entry import ScheduleEntry
from firewheel.vm_resource_manager.vm_resource_store import VmResourceStore

def create_break_schedule_entry(start_time: int | float) -> ScheduleEntry:
    """Create a break schedule entry.

    A break event is represented as a ``ScheduleEntry`` with a pause event of
    infinite duration. This recreates the essential behavior of
    ``PauseScheduleEntry(start_time, math.inf)`` for use in this helper.

    Args:
        start_time: Time at which the break should begin. Must be ``math.inf``,
            ``-math.inf``, ``0``, or any positive value. In practice, ``0`` is
            converted to ``sys.float_info.min`` to match FIREWHEEL behavior.

    Returns:
        A schedule entry containing an indefinite pause event.

    Raises:
        ValueError: If ``start_time`` is a negative finite value.
    """
    if start_time < 0 and not math.isinf(start_time):
        raise ValueError(
            "Valid start times for pause and break only include negative "
            "infinity or greater than or equal to 0."
        )

    normalized_start_time: int | float = start_time
    if start_time == 0:
        normalized_start_time = sys.float_info.min

    break_entry = ScheduleEntry(normalized_start_time)
    break_entry.add_pause(math.inf)
    return break_entry


def prepend_break_to_schedule(
    schedule_entries: list[ScheduleEntry],
    start_time: int | float,
) -> list[ScheduleEntry]:
    """Prepend a break entry to a list of schedule entries.

    Args:
        schedule_entries: Existing schedule entries.
        start_time: Time at which the break should begin.

    Returns:
        A new list whose first element is a break entry followed by the
        provided schedule entries.

    Raises:
        ValueError: If ``start_time`` is invalid for a break entry.
    """
    break_entry = create_break_schedule_entry(start_time)
    return [break_entry, *schedule_entries]

def check_time():
    experiment_time = vm_resource_api.get_experiment_start_time()

    # Time zone is UTC by definition.
    if not experiment_time:
        raise RuntimeError("Experiment must have a start time prior to saving!")

    seconds_since_start = vm_resource_api.get_experiment_time_since_start()
    if seconds_since_start:
        seconds_since_start = int(seconds_since_start)
    else:
        seconds_since_start = 0

    time_obj = {
        "start_time": f"{experiment_time.isoformat()}",
        "seconds_since_start": seconds_since_start,
    }
    return time_obj

def prune_schedule_entries(
    seconds_since_start: int,
    schedule_path: Path,
    output_location: Path,
    console: Console,
) -> None:
    """Prune completed schedule entries and prepend a break event.

    Args:
        seconds_since_start: The number of seconds since the experiment started.
        schedule_path: The location of the schedule file to modify.
        output_location: The location to save the pruned schedule file.
        console: Console object used for output.

    Raises:
        RuntimeError: If the schedule file cannot be read, decoded, or written.
    """
    schedule_obj: dict[str, Any] | None = None
    try:
        with schedule_path.open("r", encoding="utf8") as f_name:
            schedule_obj = json.load(f_name)
            decoded_text = base64.b64decode(schedule_obj["text"])
            schedule_obj["text"] = decoded_text
    except FileNotFoundError as exp:
        console.print(f"[error]Schedule file not found at {schedule_path}: {exp}[/error]")
        raise RuntimeError(f"Schedule file not found at {schedule_path}: {exp}") from exp
    except json.JSONDecodeError as exp:
        console.print(
            f"[error]Error decoding JSON from schedule file {schedule_path}: {exp}[/error]"
        )
        raise RuntimeError(
            f"Error decoding JSON from schedule file {schedule_path}: {exp}"
        ) from exp

    try:
        cur_schedule: list[ScheduleEntry] = pickle.loads(schedule_obj["text"])
    except pickle.UnpicklingError as exp:
        console.print(f"[error]Error loading schedule file {schedule_path}: {exp}[/error]")
        raise RuntimeError(f"Error loading schedule file {schedule_path}: {exp}") from exp

    updated_schedule: list[ScheduleEntry] = []
    for entry in cur_schedule:
        if entry.start_time > seconds_since_start:
            updated_schedule.append(entry)

    # Prepend a break so resumed experiments remain paused until explicitly resumed.
    updated_schedule = prepend_break_to_schedule(
        schedule_entries=updated_schedule,
        start_time=0,
    )

    updated_schedule_obj = {
        "text": base64.b64encode(pickle.dumps(updated_schedule)).decode("UTF-8"),
        "server_name": schedule_obj["server_name"],
        "ip": schedule_obj["ip"],
    }

    try:
        with output_location.open("w", encoding="utf8") as f_name:
            json.dump(updated_schedule_obj, f_name)
    except OSError as exp:
        console.print(
            f"[error]Error writing updated schedule file to {output_location}: {exp}[/error]"
        )
        raise RuntimeError(
            f"Error writing updated schedule file to {output_location}: {exp}"
        ) from exp
        
                
def save_vm_state(
    experiment_name: str = "firewheel_experiment",
    complete: bool = False,
    archive: bool = False,
) -> int:
    """Save the current VM state and schedule data.

    This function saves the current experiment state into a directory named
    ``<experiment_name>_backup`` in the current working directory. If
    ``archive`` is True, that directory is additionally compressed into a
    ``.tar.gz`` archive.

    Args:
        experiment_name: The name of the experiment to save.
        complete: If True, save all files from the experiment, including cached
            images and VM resources.
        archive: If True, archive the saved output directory as a ``.tar.gz``
            file.

    Returns:
        ``0`` on success and ``1`` on failure.

    Raises:
        RuntimeError: If the FileStore connection fails.
    """
    console = Console(theme=cli_output_theme)

    mm_api = minimegaAPI()

    try:
        experiment_time = check_time()
    except RuntimeError as exc:
        console.print(f"[error]ERROR: saving namespace: {exc}[/error]")
        return 1

    try:
        with console.status(
            "[yellow]Calling minimega to save namespace...[/yellow]",
            spinner="line",
        ):
            mm_api.mm.ns_save(name=experiment_name)
        console.print("[green]Namespace saved successfully.[/green]")
    except minimega.Error as exp:
        console.print(f"[error]Error saving namespace: {exp}[/error]")
        return 1

    try:
        saved_exp = FileStore("saved")
    except Exception as exp:
        console.print("[error]FileStore connection failed.[/error]")
        raise RuntimeError(
            f"Invalid value for FileStore connection. Details: {exp}"
        ) from exp

    exp_files = Path(saved_exp.get_file_path(experiment_name))

    vm_mapping = VMMapping()
    schedule_db = ScheduleDb()

    mapping = vm_mapping.get_all()
    files = schedule_db.cache.list_distinct_contents()
    schedule_db_paths = [Path(schedule_db.cache.get_path(file)) for file in files]

    output_dir = Path.cwd() / f"{experiment_name}_backup"

    if output_dir.exists():
        console.print(
            f"[error]Output directory [cyan]{output_dir}[/cyan] already exists.[/error]"
        )
        return 1

    try:
        output_dir.mkdir(parents=True, exist_ok=False)
    except OSError as exc:
        console.print(
            f"[error]Could not create output directory [cyan]{output_dir}[/cyan]: {exc}[/error]"
        )
        return 1

    # Copy the saved namespace files to the output directory.
    try:
        if exp_files.exists():
            with console.status(
                "[yellow]Copying VM State/HDD files...[/yellow]",
                spinner="line",
            ):
                shutil.copytree(exp_files, output_dir / exp_files.name)
            console.print(
                "[green]Copied VM State/HDD files from "
                f"[cyan]{exp_files}[/cyan] to [cyan]{output_dir}[/cyan]"
            )
        else:
            console.print(
                "[yellow]The VM State/HDD files at "
                f"[cyan]{exp_files}[/cyan] do not exist![/yellow]"
            )
    except OSError as exc:
        console.print(
            f"[error]Error copying VM State/HD directory [cyan]{exp_files}[/cyan]: {exc}[/error]"
        )

    mapping_file = output_dir / "vm_mapping.json"
    try:
        with mapping_file.open("w", encoding="utf-8") as f:
            json.dump(mapping, f)
        console.print(
            f"[green]VM mapping states saved to [cyan]{mapping_file}[/cyan] successfully.[/green]"
        )
    except OSError as exc:
        console.print(f"[error]Error saving VM mapping states to file: {exc}[/error]")
        return 1

    time_file = output_dir / "experiment_time.json"
    try:
        with time_file.open("w", encoding="utf-8") as f:
            json.dump(experiment_time, f)
        console.print(
            f"[green]Experiment time saved to [cyan]{time_file}[/cyan] successfully.[/green]"
        )
    except OSError as exc:
        console.print(f"[error]Error saving experiment time to file: {exc}[/error]")
        return 1

    with Progress(
        TextColumn("[progress.description]{task.description}"),
        BarColumn(),
        MofNCompleteColumn(),
        TimeRemainingColumn(),
    ) as progress:
        task = progress.add_task(
            "[green]Copying schedule files...",
            total=len(schedule_db_paths),
        )

        schedule_dir = output_dir / "schedules"
        schedule_dir.mkdir(parents=True, exist_ok=True)
        for file in schedule_db_paths:
            try:
                prune_schedule_entries(
                    experiment_time["seconds_since_start"],
                    file,
                    schedule_dir / file.name,
                    console,
                )
            except RuntimeError:
                return 1

            progress.update(task, advance=1)

    if complete:
        image_store = ImageStore()
        img_files = Path(image_store.cache)
        try:
            if img_files.exists():
                with console.status(
                    "[yellow]Copying ImageStore cache...[/yellow]",
                    spinner="line",
                ):
                    shutil.copytree(img_files, output_dir / img_files.name)
                console.print(
                    "[green]Copied Image files from "
                    f"[cyan]{img_files}[/cyan] to [cyan]{output_dir}[/cyan]"
                )
            else:
                console.print(
                    f"[yellow]The Image files at [cyan]{img_files}[/cyan] do not exist[/yellow]"
                )
        except OSError as exc:
            console.print(
                f"[error]Error copying Image directory [cyan]{img_files}[/cyan]: {exc}[/error]"
            )

        vmr_store = VmResourceStore()
        vmr_files = Path(vmr_store.cache)
        try:
            if vmr_files.exists():
                with console.status(
                    "[yellow]Copying VM Resource cache...[/yellow]",
                    spinner="line",
                ):
                    shutil.copytree(vmr_files, output_dir / vmr_files.name)
                console.print(
                    "[green]Copied VM Resources files from "
                    f"[cyan]{vmr_files}[/cyan] to [cyan]{output_dir}[/cyan]"
                )
            else:
                console.print(
                    f"[yellow]The VM Resources files at [cyan]{vmr_files}[/cyan] do not exist[/yellow]"
                )
        except OSError as exc:
            console.print(
                f"[error]Error copying VM Resources directory [cyan]{vmr_files}[/cyan]: {exc}[/error]"
            )

    vmr_launch_cmds = Path(config["logging"]["root_dir"]) / "launch_cmds.mm"
    if vmr_launch_cmds.exists():
        try:
            shutil.copy(vmr_launch_cmds, output_dir)
            console.print("[green]Copied VM Resources Handler Launch file.[/green]")
        except OSError as exc:
            console.print(
                "[error]Error copying VM Resources Handler Launch file "
                f"[cyan]{vmr_launch_cmds}[/cyan]: {exc}[/error]"
            )
    else:
        console.print(
            "[yellow]The VM Resources Handler Launch file at "
            f"[cyan]{vmr_launch_cmds}[/cyan] does not exist[/yellow]"
        )

    if archive:
        archive_base = Path.cwd() / f"{experiment_name}_backup"
        try:
            with console.status("[yellow]Compressing data...[/yellow]", spinner="line"):
                shutil.make_archive(
                    str(archive_base),
                    "gztar",
                    root_dir=output_dir.parent,
                    base_dir=output_dir.name,
                )
            console.print(
                f"[green]Compressed data saved to [cyan]{archive_base}.tar.gz[/cyan] successfully.[/green]"
            )
        except OSError as exc:
            console.print(f"[error]Error compressing output directory: {exc}[/error]")
            return 1

    console.print(
        f"[green]VM state saved to [cyan]{output_dir}[/cyan] successfully.[/green]"
    )
    return 0


if __name__ == "__main__":
    parser = argparse.ArgumentParser(
        description="Save VM state and schedule files.",
        prog="firewheel save",
    )
    default_experiment_name = (
        f"firewheel_experiment_{datetime.now(UTC).strftime('%Y%m%dT%H%M%SZ')}"
    )
    parser.add_argument(
        "-n",
        "--name",
        type=str,
        default=default_experiment_name,
        help=(
            "Name of the experiment to save. "
            f'Default: "{default_experiment_name}".'
        ),
    )
    parser.add_argument(
        "-c",
        "--complete",
        action="store_true",
        help=(
            "If provided, save all files from the experiment, including cached "
            "images and VM resources."
        ),
    )
    parser.add_argument(
        "-a",
        "--archive",
        action="store_true",
        help="If provided, archive the saved experiment directory as a .tar.gz file.",
    )
    args = parser.parse_args()
    sys.exit(
        save_vm_state(
            experiment_name=args.name,
            complete=args.complete,
            archive=args.archive,
        )
    )

