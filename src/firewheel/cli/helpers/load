    table.add_row("Root directory", str(layout.root_dir))
    table.add_row("Experiment name", str(manifest.get("experiment_name", layout.experiment_dir.name)))
    table.add_row("Experiment dir", layout.experiment_dir.name)
    table.add_row("Format version", str(manifest.get("format_version")))
