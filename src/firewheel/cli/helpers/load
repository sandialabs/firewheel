def _validate_destination_paths(
    layout: BackupLayout,
    saved_exp_path: Path,
    schedule_db: ScheduleDb,
    imagestore_cache: Path,
    vm_resource_cache: Path,
    force: bool,
) -> None:
    """Validate restore destination paths before modifying the system.

    Existing identical content is allowed and will be skipped during restore.
    Only differing content requires ``--force``.

    Args:
        layout: Validated backup layout.
        saved_exp_path: Target saved experiment path.
        schedule_db: Schedule database handle.
        imagestore_cache: ImageStore cache path.
        vm_resource_cache: VmResourceStore cache path.
        force: Whether overwriting existing differing content is allowed.

    Raises:
        FileExistsError: If an existing destination differs and force is False.
    """
    conflicts: list[str] = []

    if saved_exp_path.exists():
        if not _directories_are_identical(layout.experiment_dir, saved_exp_path) and not force:
            conflicts.append(str(saved_exp_path))

    schedule_cache_root = Path(schedule_db.cache.cache)
    for schedule_file in layout.schedules_dir.iterdir():
        if not schedule_file.is_file():
            continue
        dest = schedule_cache_root / schedule_file.name
        if dest.exists():
            if not _files_are_identical(schedule_file, dest) and not force:
                conflicts.append(str(dest))

    if layout.imagestore_dir is not None and imagestore_cache.exists():
        if not _directories_are_identical(layout.imagestore_dir, imagestore_cache) and not force:
            conflicts.append(str(imagestore_cache))

    if layout.vm_resource_store_dir is not None and vm_resource_cache.exists():
        if not _directories_are_identical(layout.vm_resource_store_dir, vm_resource_cache) and not force:
            conflicts.append(str(vm_resource_cache))

    if conflicts:
        conflict_text = "\n".join(f"  - {item}" for item in conflicts)
        raise FileExistsError(
            "Restore would overwrite existing paths with different contents:\n"
            f"{conflict_text}\n"
            "Rerun with --force to overwrite differing content."
        )


def _restore_from_layout(
    layout: BackupLayout,
    dry_run: bool,
    force: bool,
) -> int:
    """Restore VM state from a validated backup layout."""
    _print_validation_summary(layout)

    try:
        saved_exp = FileStore("saved")
        vm_mapping = VMMapping()
        schedule_db = ScheduleDb()
        image_store = ImageStore()
        vm_resource_store = VmResourceStore()
    except Exception as exc:
        console.print(f"[red]Failed to initialize restore dependencies: {exc}[/red]")
        return 1

    experiment_name = str(layout.manifest.get("experiment_name", layout.experiment_dir.name))
    saved_exp_path = Path(saved_exp.get_file_path(layout.experiment_dir.name))
    imagestore_cache = Path(image_store.cache)
    vm_resource_cache = Path(vm_resource_store.cache)

    try:
        _validate_destination_paths(
            layout=layout,
            saved_exp_path=saved_exp_path,
            schedule_db=schedule_db,
            imagestore_cache=imagestore_cache,
            vm_resource_cache=vm_resource_cache,
            force=force,
        )
    except FileExistsError as exc:
        console.print(f"[red]{exc}[/red]")
        return 1

    if dry_run:
        console.rule("[bold yellow]Dry Run Summary[/bold yellow]")
        console.print("[green]Backup validation succeeded.[/green]")
        console.print(f"[green]Experiment:[/green] [cyan]{experiment_name}[/cyan]")
        console.print(f"[green]Would restore saved experiment files to:[/green] [cyan]{saved_exp_path}[/cyan]")
        console.print(f"[green]Would restore VM mapping from:[/green] [cyan]{layout.vm_mapping_path}[/cyan]")
        console.print(f"[green]Would restore schedules from:[/green] [cyan]{layout.schedules_dir}[/cyan]")
        console.print(f"[green]Would launch saved VMs via:[/green] [cyan]{layout.launch_mm_path}[/cyan]")
        if layout.launch_cmds_path is not None:
            console.print(
                f"[green]Would rewrite and launch VM resource handlers from:[/green] "
                f"[cyan]{layout.launch_cmds_path}[/cyan]"
            )
        if layout.imagestore_dir is not None:
            console.print(
                f"[green]Would restore ImageStore cache to:[/green] [cyan]{imagestore_cache}[/cyan]"
            )
        if layout.vm_resource_store_dir is not None:
            console.print(
                "[green]Would restore VmResourceStore cache to:[/green] "
                f"[cyan]{vm_resource_cache}[/cyan]"
            )
        console.print("[green]Existing identical files/directories would be reused without overwrite.[/green]")
        console.print("[green]Would restore experiment time last.[/green]")
        return 0

    summary: dict[str, Any] = {
        "experiment_name": experiment_name,
        "saved_exp_path": str(saved_exp_path),
        "vm_mapping_entries": 0,
        "schedule_files_processed": 0,
        "schedule_files_copied": 0,
        "experiment_files_copied": False,
        "experiment_files_reused": False,
        "imagestore_present": False,
        "imagestore_copied": False,
        "vm_resource_cache_present": False,
        "vm_resource_cache_copied": False,
        "started_vms": False,
        "started_vm_resource_handlers": False,
        "restored_experiment_time": False,
    }

    try:
        experiment_files_copied = _restore_experiment_files(
            exp_files=layout.experiment_dir,
            destination=saved_exp_path,
            force=force,
        )
        summary["experiment_files_copied"] = experiment_files_copied
        summary["experiment_files_reused"] = not experiment_files_copied

        imagestore_present, imagestore_copied = _restore_optional_cache(
            source_dir=layout.imagestore_dir,
            destination_dir=imagestore_cache,
            force=force,
        )
        summary["imagestore_present"] = imagestore_present
        summary["imagestore_copied"] = imagestore_copied

        vm_resource_cache_present, vm_resource_cache_copied = _restore_optional_cache(
            source_dir=layout.vm_resource_store_dir,
            destination_dir=vm_resource_cache,
            force=force,
        )
        summary["vm_resource_cache_present"] = vm_resource_cache_present
        summary["vm_resource_cache_copied"] = vm_resource_cache_copied

        summary["vm_mapping_entries"] = _restore_vm_mapping(
            layout.vm_mapping_path,
            vm_mapping,
        )

        (
            summary["schedule_files_processed"],
            summary["schedule_files_copied"],
        ) = _restore_schedule_files(
            layout.schedules_dir,
            schedule_db,
            force=force,
        )

        _run_minimega_script(saved_exp_path / "launch.mm", "Started saved VMs")
        summary["started_vms"] = True

        if layout.launch_cmds_path is not None:
            mm_api = minimegaAPI()
            launch_cmd_updated_path = layout.root_dir / "launch_cmds_updated.mm"
            vm_name_to_mm_id = rebuild_launch_cmds_file_with_current_mm_ids(
                input_path=layout.launch_cmds_path,
                output_path=launch_cmd_updated_path,
                mm_api=mm_api,
            )
            console.print(
                f"[green]Mapped VM names to minimega IDs:[/green] [cyan]{vm_name_to_mm_id}[/cyan]"
            )
            _run_minimega_script(
                launch_cmd_updated_path,
                "Started VM Resource scripts",
            )
            summary["started_vm_resource_handlers"] = True

        _restore_experiment_time(layout.experiment_time_path)
        summary["restored_experiment_time"] = True

    except Exception as exc:
        console.print(f"[red]Restore failed: {exc}[/red]")
        _rollback_guidance()
        return 1

    console.rule("[bold green]Load Summary[/bold green]")
    table = Table(title="Restore Result")
    table.add_column("Field", style="cyan")
    table.add_column("Value", style="green")

    table.add_row("Experiment", str(summary["experiment_name"]))
    table.add_row("Saved experiment path", str(summary["saved_exp_path"]))
    table.add_row("Experiment files copied", str(summary["experiment_files_copied"]))
    table.add_row("Experiment files reused", str(summary["experiment_files_reused"]))
    table.add_row("VM mapping entries restored", str(summary["vm_mapping_entries"]))
    table.add_row("Schedule files processed", str(summary["schedule_files_processed"]))
    table.add_row("Schedule files copied", str(summary["schedule_files_copied"]))
    table.add_row("ImageStore cache present", str(summary["imagestore_present"]))
    table.add_row("ImageStore cache copied", str(summary["imagestore_copied"]))
    table.add_row(
        "VmResourceStore cache present",
        str(summary["vm_resource_cache_present"]),
    )
    table.add_row(
        "VmResourceStore cache copied",
        str(summary["vm_resource_cache_copied"]),
    )
    table.add_row("VMs launched", str(summary["started_vms"]))
    table.add_row(
        "VM resource handlers launched",
        str(summary["started_vm_resource_handlers"]),
    )
    table.add_row(
        "Experiment time restored",
        str(summary["restored_experiment_time"]),
    )

    console.print(table)
    return 0


def load_vm_state(
    source: str,
    dry_run: bool = False,
    force: bool = False,
) -> int:
    """Load VM state from a backup directory or supported archive."""
    source_path = Path(source).resolve()

    if not source_path.exists():
        console.print(f"[red]Error: Path [cyan]{source_path}[/cyan] does not exist.[/red]")
        return 1

    if source_path.is_file():
        if not is_supported_archive(source_path):
            console.print(
                f"[red]Error: File [cyan]{source_path}[/cyan] is not a supported archive. "
                f"Expected one of: .tar.gz, .tgz, .tar[/red]"
            )
            return 1

        try:
            with tempfile.TemporaryDirectory() as temp_dir:
                temp_path = Path(temp_dir)
                with console.status(
                    "[yellow]Decompressing experiment archive...[/yellow]",
                    spinner="line",
                ):
                    extract_archive_safely(source_path, temp_path)

                extracted_dirs = [p for p in temp_path.iterdir() if p.is_dir()]
                if len(extracted_dirs) != 1:
                    console.print(
                        "[red]Archive must extract to exactly one top-level backup directory.[/red]"
                    )
                    return 1

                layout = validate_backup_directory(extracted_dirs[0])
                return _restore_from_layout(layout, dry_run=dry_run, force=force)

        except Exception as exc:
            console.print(f"[red]Failed to load archive [cyan]{source_path}[/cyan]: {exc}[/red]")
            return 1

    if source_path.is_dir():
        try:
            layout = validate_backup_directory(source_path)
            return _restore_from_layout(layout, dry_run=dry_run, force=force)
        except Exception as exc:
            console.print(
                f"[red]Invalid backup directory [cyan]{source_path}[/cyan]: {exc}[/red]"
            )
            return 1

    console.print(
        f"[red]Error: Path [cyan]{source_path}[/cyan] is neither a regular file nor a directory.[/red]"
    )
    return 1


if __name__ == "__main__":
    parser = argparse.ArgumentParser(
        description="Load VM state and schedule files from a backup directory or archive.",
        prog="firewheel load",
    )
    parser.add_argument(
        "source",
        type=str,
        help="Path to the backup archive or extracted backup directory.",
    )
    parser.add_argument(
        "--dry-run",
        action="store_true",
        help="Validate the backup and restore targets without making changes.",
    )
    parser.add_argument(
        "--force",
        action="store_true",
        help="Overwrite existing restore destinations only when contents differ.",
    )
    args = parser.parse_args()
    sys.exit(
        load_vm_state(
            source=args.source,
            dry_run=args.dry_run,
            force=args.force,
        )
    )
