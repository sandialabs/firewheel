#!/usr/bin/env python
import os
import sys
import json
import shutil
import argparse
import tarfile
import tempfile
import subprocess
from pathlib import Path

from rich.console import Console

from firewheel.config import config as fw_config
from firewheel.cli.utils import cli_output_theme
from firewheel.lib.minimega.file_store import FileStore
from firewheel.vm_resource_manager.vm_mapping import VMMapping
from firewheel.vm_resource_manager.schedule_db import ScheduleDb

console = Console(theme=cli_output_theme)


def _derive_experiment_name_from_archive(path: Path) -> str:
    """
    Derive the experiment name from an archive filename.
    Example:
      myexp_backup.tar.gz -> myexp
      myexp_backup.tgz    -> myexp
      myexp.tar           -> myexp
    """
    name = path.name

    if name.endswith(".tar.gz"):
        name = name[:-7]
    elif name.endswith(".tgz"):
        name = name[:-4]
    elif name.endswith(".tar"):
        name = name[:-4]

    if "_backup" in name:
        name = name.split("_backup")[0]

    return name


def _is_supported_archive(path: Path) -> bool:
    """
    Return True if the path appears to be a supported tar archive.
    """
    return (
        path.name.endswith(".tar.gz")
        or path.name.endswith(".tgz")
        or path.name.endswith(".tar")
    )


def _find_experiment_dir(source_dir: Path) -> Path:
    """
    Find the single experiment directory inside source_dir.

    Expected non-experiment entries include:
      - vm_mapping.json
      - launch_cmds.mm
      - schedules/

    Returns:
        Path: The experiment directory.

    Raises:
        FileNotFoundError: If no candidate experiment directory is found.
        ValueError: If multiple candidate experiment directories are found.
        OSError: If source_dir cannot be read.
    """
    excluded_names = {"schedules", "__MACOSX"}

    candidates = [
        p for p in source_dir.iterdir()
        if p.is_dir() and p.name not in excluded_names
    ]

    if not candidates:
        raise FileNotFoundError(
            f"No experiment directory found in {source_dir}"
        )

    if len(candidates) > 1:
        candidate_names = ", ".join(sorted(p.name for p in candidates))
        raise ValueError(
            f"Multiple experiment directories found in {source_dir}: {candidate_names}"
        )

    return candidates[0]


def _validate_restore_directory(source_dir: Path) -> Path:
    """
    Validate that source_dir contains the required files and structure.

    Expected:
      source_dir/
        vm_mapping.json
        launch_cmds.mm
        schedules/
        <experiment_name>/
          launch.mm

    Returns:
        Path: The experiment directory path.

    Raises:
        FileNotFoundError, NotADirectoryError, ValueError
    """
    mapping_file = source_dir / "vm_mapping.json"
    if not mapping_file.exists():
        raise FileNotFoundError(f"Missing required file: {mapping_file}")
    if not mapping_file.is_file():
        raise FileNotFoundError(f"Expected a file but found otherwise: {mapping_file}")

    launch_cmds = source_dir / "launch_cmds.mm"
    if not launch_cmds.exists():
        raise FileNotFoundError(f"Missing required file: {launch_cmds}")
    if not launch_cmds.is_file():
        raise FileNotFoundError(f"Expected a file but found otherwise: {launch_cmds}")

    schedule_dir = source_dir / "schedules"
    if not schedule_dir.exists():
        raise FileNotFoundError(f"Missing required directory: {schedule_dir}")
    if not schedule_dir.is_dir():
        raise NotADirectoryError(f"Expected a directory: {schedule_dir}")

    exp_dir = _find_experiment_dir(source_dir)

    launch_mm = exp_dir / "launch.mm"
    if not launch_mm.exists():
        raise FileNotFoundError(
            f"Experiment directory {exp_dir} is missing required file: {launch_mm}"
        )
    if not launch_mm.is_file():
        raise FileNotFoundError(f"Expected a file but found otherwise: {launch_mm}")

    return exp_dir


def _extract_archive(archive_file: Path, temp_path: Path) -> None:
    """
    Extract archive_file into temp_path.

    Raises:
        tarfile.ReadError
        tarfile.CompressionError
        PermissionError
        OSError
    """
    with tarfile.open(archive_file, "r:*") as tar:
        with console.status("[yellow]Decompressing experiment archive...[/yellow]", spinner="line"):
            tar.extractall(path=temp_path)

    console.print(
        f"[green]Extracted data from [cyan]{archive_file}[/cyan] to [cyan]{temp_path}[/cyan].[/green]"
    )


def _restore_vm_mapping(mapping_file: Path, vm_mapping: VMMapping) -> None:
    """
    Restore VM mapping state from mapping_file.

    Raises:
        FileNotFoundError
        PermissionError
        json.JSONDecodeError
        OSError
    """
    with mapping_file.open("r", encoding="utf-8") as f:
        mapping = json.load(f)

    vm_mapping.batch_put(mapping)

    console.print(
        f"[green]Restored VM mapping states from [cyan]{mapping_file}[/cyan] successfully.[/green]"
    )


def _restore_experiment_files(exp_files: Path, destination: Path) -> None:
    """
    Restore VM state/HDD files from exp_files into destination.

    Raises:
        FileExistsError
        FileNotFoundError
        PermissionError
        OSError
    """
    shutil.copytree(exp_files, destination)
    console.print(
        f"[green]Restored VM State/HDD files from [cyan]{exp_files}[/cyan] "
        f"to [cyan]{destination}[/cyan].[/green]"
    )


def _restore_schedule_files(schedule_dir: Path, schedule_db: ScheduleDb) -> None:
    """
    Restore schedule files from schedule_dir into the schedule cache.

    Raises:
        PermissionError
        OSError
    """
    for file in schedule_dir.iterdir():
        if file.is_file():
            shutil.copy(file, schedule_db.cache.cache)
            console.print(f"[green]Restored schedule file [cyan]{file}[/cyan] successfully.[/green]")


def _run_minimega_script(script_path: Path, description: str) -> None:
    """
    Run a minimega script.

    Raises:
        subprocess.CalledProcessError
        FileNotFoundError
        PermissionError
        OSError
    """
    minimega_bin_path = os.path.join(
        fw_config["minimega"]["install_dir"], "bin", "minimega"
    )

    result = subprocess.run(
        [
            minimega_bin_path,
            f"-base={fw_config['minimega']['base_dir']}",
            "-e",
            "read",
            str(script_path),
        ],
        check=True,
    )

    console.print(f"[green]{description}: ret={result.returncode}.[/green]")


def _restore_from_directory(source_dir: Path) -> int:
    """
    Restore VM mappings, experiment files, schedules, and start scripts
    from a validated directory structure.
    """
    try:
        exp_dir = _validate_restore_directory(source_dir)
    except FileNotFoundError as exc:
        console.print(f"[red]Invalid restore directory: {exc}[/red]")
        return 1
    except NotADirectoryError as exc:
        console.print(f"[red]Invalid restore directory: {exc}[/red]")
        return 1
    except ValueError as exc:
        console.print(f"[red]Invalid restore directory layout: {exc}[/red]")
        return 1
    except OSError as exc:
        console.print(f"[red]Unable to inspect restore directory [cyan]{source_dir}[/cyan]: {exc}[/red]")
        return 1

    experiment_name = exp_dir.name

    try:
        saved_exp = FileStore("saved")
        vm_mapping = VMMapping()
        schedule_db = ScheduleDb()
    except OSError as exc:
        console.print(f"[red]OS error initializing resources: {exc}[/red]")
        return 1
    except ValueError as exc:
        console.print(f"[red]Configuration error initializing resources: {exc}[/red]")
        return 1

    mapping_file = source_dir / "vm_mapping.json"
    try:
        _restore_vm_mapping(mapping_file, vm_mapping)
    except FileNotFoundError as exc:
        console.print(f"[red]Required mapping file not found: {exc}[/red]")
        return 1
    except PermissionError as exc:
        console.print(f"[red]Permission denied reading mapping file: {exc}[/red]")
        return 1
    except json.JSONDecodeError as exc:
        console.print(f"[red]Invalid JSON in mapping file [cyan]{mapping_file}[/cyan]: {exc}[/red]")
        return 1
    except OSError as exc:
        console.print(f"[red]Error restoring VM mapping state: {exc}[/red]")
        return 1

    saved_exp_path = Path(saved_exp.get_file_path(experiment_name))
    try:
        _restore_experiment_files(exp_dir, saved_exp_path)
    except FileExistsError:
        console.print(
            f"[yellow]The VM State/HDD files for experiment [cyan]{experiment_name}[/cyan] "
            f"already exist at [cyan]{saved_exp_path}[/cyan]. Using in-place files instead.[/yellow]"
        )
    except FileNotFoundError as exc:
        console.print(f"[red]Experiment files not found: {exc}[/red]")
        return 1
    except PermissionError as exc:
        console.print(f"[red]Permission denied restoring experiment files: {exc}[/red]")
        return 1
    except OSError as exc:
        console.print(f"[red]Error restoring VM State/HDD directory: {exc}[/red]")
        return 1

    schedule_dir = source_dir / "schedules"
    try:
        _restore_schedule_files(schedule_dir, schedule_db)
    except PermissionError as exc:
        console.print(f"[red]Permission denied restoring schedule files: {exc}[/red]")
        return 1
    except OSError as exc:
        console.print(f"[red]Error restoring schedule files: {exc}[/red]")
        return 1

    try:
        _run_minimega_script(source_dir / "launch_cmds.mm", "Started VM Resource scripts")
    except FileNotFoundError as exc:
        console.print(f"[red]minimega or launch script not found: {exc}[/red]")
        return 1
    except PermissionError as exc:
        console.print(f"[red]Permission denied running VM resource scripts: {exc}[/red]")
        return 1
    except subprocess.CalledProcessError as exc:
        console.print(f"[red]Error starting VM resource scripts: {exc}[/red]")
        return 1
    except OSError as exc:
        console.print(f"[red]OS error running VM resource scripts: {exc}[/red]")
        return 1

    try:
        _run_minimega_script(saved_exp_path / "launch.mm", "Started saved VMs")
    except FileNotFoundError as exc:
        console.print(f"[red]minimega or VM launch script not found: {exc}[/red]")
        return 1
    except PermissionError as exc:
        console.print(f"[red]Permission denied starting VMs: {exc}[/red]")
        return 1
    except subprocess.CalledProcessError as exc:
        console.print(f"[red]Error starting VMs: {exc}[/red]")
        return 1
    except OSError as exc:
        console.print(f"[red]OS error starting VMs: {exc}[/red]")
        return 1

    return 0


def load_vm_state(input_path: str) -> int:
    """
    Load VM state and schedules from either:
      - a tar archive, or
      - a directory containing the extracted restore content
    """
    source_path = Path(input_path).resolve()

    if not source_path.exists():
        console.print(f"[red]Error: Path [cyan]{source_path}[/cyan] does not exist.[/red]")
        return 1

    if source_path.is_file():
        if not _is_supported_archive(source_path):
            console.print(
                f"[red]Error: File [cyan]{source_path}[/cyan] is not a supported archive. "
                f"Expected one of: .tar.gz, .tgz, .tar[/red]"
            )
            return 1

        try:
            with tempfile.TemporaryDirectory() as temp_dir:
                temp_path = Path(temp_dir)
                _extract_archive(source_path, temp_path)
                return _restore_from_directory(temp_path)
        except tarfile.ReadError as exc:
            console.print(
                f"[red]Error: File [cyan]{source_path}[/cyan] is not a readable tar archive: {exc}[/red]"
            )
            return 1
        except tarfile.CompressionError as exc:
            console.print(
                f"[red]Error: Unsupported or invalid archive compression for [cyan]{source_path}[/cyan]: {exc}[/red]"
            )
            return 1
        except PermissionError as exc:
            console.print(f"[red]Permission denied accessing archive [cyan]{source_path}[/cyan]: {exc}[/red]")
            return 1
        except OSError as exc:
            console.print(f"[red]OS error while processing archive [cyan]{source_path}[/cyan]: {exc}[/red]")
            return 1

    if source_path.is_dir():
        return _restore_from_directory(source_path)

    console.print(
        f"[red]Error: Path [cyan]{source_path}[/cyan] is neither a regular file nor a directory.[/red]"
    )
    return 1


if __name__ == "__main__":
    parser = argparse.ArgumentParser(
        description="Load VM state and schedule files from either an archive or a directory."
    )
    parser.add_argument(
        "source",
        type=str,
        help="Path to the compressed backup file or extracted experiment directory.",
    )
    args = parser.parse_args()
    sys.exit(load_vm_state(args.source))
