def _derive_experiment_name_from_archive(path: Path) -> str:
    """
    Derive the experiment name from an archive filename.
    Example:
      myexp_backup.tar.gz -> myexp
      myexp_backup.tgz    -> myexp
      myexp.tar           -> myexp
    """
    name = path.name

    if name.endswith(".tar.gz"):
        name = name[:-7]
    elif name.endswith(".tgz"):
        name = name[:-4]
    elif name.endswith(".tar"):
        name = name[:-4]

    if "_backup" in name:
        name = name.split("_backup")[0]

    return name


def _is_supported_archive(path: Path) -> bool:
    """
    Return True if the path appears to be a supported tar archive.
    """
    return (
        path.name.endswith(".tar.gz")
        or path.name.endswith(".tgz")
        or path.name.endswith(".tar")
    )


def _find_experiment_dir(source_dir: Path) -> Path:
    """
    Find the single experiment directory inside source_dir.

    Expected non-experiment entries include:
      - vm_mapping.json
      - launch_cmds.mm
      - schedules/

    Returns:
        Path: The experiment directory.

    Raises:
        FileNotFoundError: If no candidate experiment directory is found.
        ValueError: If multiple candidate experiment directories are found.
        OSError: If source_dir cannot be read.
    """
    excluded_names = {"schedules", "__MACOSX"}

    candidates = [
        p for p in source_dir.iterdir()
        if p.is_dir() and p.name not in excluded_names
    ]

    if not candidates:
        raise FileNotFoundError(
            f"No experiment directory found in {source_dir}"
        )

    if len(candidates) > 1:
        candidate_names = ", ".join(sorted(p.name for p in candidates))
        raise ValueError(
            f"Multiple experiment directories found in {source_dir}: {candidate_names}"
        )

    return candidates[0]


def _validate_restore_directory(source_dir: Path) -> Path:
    """
    Validate that source_dir contains the required files and structure.

    Expected:
      source_dir/
        vm_mapping.json
        launch_cmds.mm
        schedules/
        <experiment_name>/
          launch.mm

    Returns:
        Path: The experiment directory path.

    Raises:
        FileNotFoundError, NotADirectoryError, ValueError
    """
    mapping_file = source_dir / "vm_mapping.json"
    if not mapping_file.exists():
        raise FileNotFoundError(f"Missing required file: {mapping_file}")
    if not mapping_file.is_file():
        raise FileNotFoundError(f"Expected a file but found otherwise: {mapping_file}")

    launch_cmds = source_dir / "launch_cmds.mm"
    if not launch_cmds.exists():
        raise FileNotFoundError(f"Missing required file: {launch_cmds}")
    if not launch_cmds.is_file():
        raise FileNotFoundError(f"Expected a file but found otherwise: {launch_cmds}")

    schedule_dir = source_dir / "schedules"
    if not schedule_dir.exists():
        raise FileNotFoundError(f"Missing required directory: {schedule_dir}")
    if not schedule_dir.is_dir():
        raise NotADirectoryError(f"Expected a directory: {schedule_dir}")

    exp_dir = _find_experiment_dir(source_dir)

    launch_mm = exp_dir / "launch.mm"
    if not launch_mm.exists():
        raise FileNotFoundError(
            f"Experiment directory {exp_dir} is missing required file: {launch_mm}"
        )
    if not launch_mm.is_file():
        raise FileNotFoundError(f"Expected a file but found otherwise: {launch_mm}")

    return exp_dir


def _extract_archive(archive_file: Path, temp_path: Path) -> None:
    """
    Extract archive_file into temp_path.

    Raises:
        tarfile.ReadError
        tarfile.CompressionError
        PermissionError
        OSError
    """
    with tarfile.open(archive_file, "r:*") as tar:
        with console.status("[yellow]Decompressing experiment archive...[/yellow]", spinner="line"):
            tar.extractall(path=temp_path)

    console.print(
        f"[green]Extracted data from [cyan]{archive_file}[/cyan] to [cyan]{temp_path}[/cyan].[/green]"
    )


def _restore_vm_mapping(mapping_file: Path, vm_mapping: VMMapping) -> None:
    """
    Restore VM mapping state from mapping_file.

    Raises:
        FileNotFoundError
        PermissionError
        json.JSONDecodeError
        OSError
    """
    with mapping_file.open("r", encoding="utf-8") as f:
        mapping = json.load(f)

    vm_mapping.batch_put(mapping)

    console.print(
        f"[green]Restored VM mapping states from [cyan]{mapping_file}[/cyan] successfully.[/green]"
    )

def _restore_experiment_time(experiment_time_path: Path) -> None:
    """
    Restore the experiment start time from experiment_time_path.
    The start time of the experiment is determined by taking the current time and subtracting the
    "seconds_since_start" value stored in experiment_time_path.
    That is, the experiment time is effectively shifted to be consistent with the current time,
    but maintains the same relative timing for schedule entries.

    Arguments:
        experiment_time_path (Path): The path to the file containing the saved experiment time information.

    Raises:
        ValueError: If the "seconds_since_start" key is missing from the time file.
    """
    with experiment_time_path.open("r", encoding="utf-8") as f:
        time_obj = json.load(f)

    if "seconds_since_start" not in time_obj:
        raise ValueError(f"Missing 'seconds_since_start' key in {experiment_time_path}")

    new_start_time = datetime.now(timezone.utc) - timedelta(seconds=time_obj["seconds_since_start"])

    start = ExperimentStart()
    start.grpc_client.set_experiment_start_time(new_start_time)


def _restore_experiment_files(exp_files: Path, destination: Path) -> None:
    """
    Restore VM state/HDD files from exp_files into destination.

    Raises:
        FileExistsError
        FileNotFoundError
        PermissionError
        OSError
    """
    shutil.copytree(exp_files, destination)
    console.print(
        f"[green]Restored VM State/HDD files from [cyan]{exp_files}[/cyan] "
        f"to [cyan]{destination}[/cyan].[/green]"
    )


def _restore_schedule_files(schedule_dir: Path, schedule_db: ScheduleDb) -> None:
    """
    Restore schedule files from schedule_dir into the schedule cache.

    Raises:
        PermissionError
        OSError
    """
    for file in schedule_dir.iterdir():
        if file.is_file():
            shutil.copy(file, schedule_db.cache.cache)
            console.print(f"[green]Restored schedule file [cyan]{file}[/cyan] successfully.[/green]")


_JSON_LINE_PATTERN = re.compile(r"^(.* )'((?:\\.|[^'])*)'$")


def update_socket_path(
    process_config: dict[str, Any],
    vm_name_to_mm_id: Mapping[str, str],
    mm_base: str,
) -> None:
    """Update the socket path in a process configuration.

    The socket filename is preserved, but the directory is rebuilt using the
    new minimega ID associated with the VM name.

    Args:
        process_config: Parsed JSON configuration for a VM resource handler.
            Must contain the keys ``"path"`` and ``"vm_name"``.
        vm_name_to_mm_id: Mapping from VM name to the new minimega ID.
        mm_base: Base directory for minimega socket paths.

    Raises:
        KeyError: If ``"path"`` or ``"vm_name"`` is missing from
            ``process_config``, or if the VM name is not present in
            ``vm_name_to_mm_id``.
    """
    original_socket_path = process_config["path"]
    socket_filename = os.path.basename(original_socket_path)
    vm_name = process_config["vm_name"]
    mm_id = vm_name_to_mm_id[vm_name]
    process_config["path"] = os.path.join(mm_base, mm_id, socket_filename)


def _unescape_embedded_json(escaped_json: str) -> str:
    """Convert embedded escaped JSON text into normal JSON text.

    Args:
        escaped_json: JSON string extracted from within single quotes in the
            command line.

    Returns:
        The unescaped JSON text suitable for ``json.loads()``.
    """
    return escaped_json.replace(r"\\", "\\").replace(r"\"", '"')


def _escape_embedded_json(json_text: str, is_mesh_command: bool) -> str:
    """Escape JSON text for reinsertion into a launch command line.

    Args:
        json_text: Normal JSON text.
        is_mesh_command: Whether the command is a ``mesh send`` command, which
            requires an additional level of escaping.

    Returns:
        Escaped JSON text suitable for embedding in the output file.
    """
    if is_mesh_command:
        return json_text.replace('"', r'\\\"')
    return json_text.replace('"', r'\"')


def parse_launch_command_line(line: str) -> tuple[str, dict[str, Any]]:
    """Parse a launch command line into its prefix and JSON configuration.

    Args:
        line: One command line from the launch command file.

    Returns:
        A tuple of:
            - the command prefix before the quoted JSON payload
            - the parsed JSON configuration dictionary

    Raises:
        ValueError: If the line does not match the expected format.
        json.JSONDecodeError: If the embedded JSON cannot be parsed.
    """
    stripped_line = line.rstrip("\n")
    match = _JSON_LINE_PATTERN.match(stripped_line)
    if match is None:
        raise ValueError(f"Could not parse launch command line: {line!r}")

    prefix, escaped_json = match.groups()
    json_text = _unescape_embedded_json(escaped_json)
    process_config = json.loads(json_text)
    return prefix, process_config


def update_launch_command_line(
    line: str,
    vm_name_to_mm_id: Mapping[str, str],
    mm_base: str,
) -> str:
    """Update the JSON ``path`` field inside a launch command line.

    Args:
        line: One command line from the launch command file.
        vm_name_to_mm_id: Mapping from VM name to new minimega ID.
        mm_base: Base directory for minimega socket paths.

    Returns:
        The updated command line.

    Raises:
        ValueError: If the line does not match the expected format.
        json.JSONDecodeError: If the embedded JSON cannot be parsed.
        KeyError: If required JSON fields or VM mappings are missing.
    """
    prefix, process_config = parse_launch_command_line(line)

    update_socket_path(process_config, vm_name_to_mm_id, mm_base)

    new_json_text = json.dumps(process_config, separators=(",", ":"))
    is_mesh_command = prefix.startswith("mesh send ")
    new_escaped_json = _escape_embedded_json(new_json_text, is_mesh_command)

    return f"{prefix}'{new_escaped_json}'"


def iter_process_configs(lines: Iterable[str]) -> list[dict[str, Any]]:
    """Extract all process configurations from launch command lines.

    Blank lines are ignored.

    Args:
        lines: Iterable of lines from a launch command file.

    Returns:
        A list of parsed process configuration dictionaries.

    Raises:
        ValueError: If any non-blank line does not match the expected format.
        json.JSONDecodeError: If embedded JSON cannot be parsed.
    """
    process_configs: list[dict[str, Any]] = []
    for line in lines:
        if not line.strip():
            continue
        _, process_config = parse_launch_command_line(line)
        process_configs.append(process_config)
    return process_configs


def build_vm_name_to_mm_id_map(
    process_configs: Iterable[Mapping[str, Any]],
    mm_api: minimegaAPI,
) -> dict[str, str]:
    """Build a VM name to minimega ID mapping from active minimega VMs.

    This function reads expected VM identity information from the launch
    command process configurations and matches them against the currently
    running VMs reported by minimega.

    Matching is attempted in this order:
        1. By UUID, if the process config contains ``"vm_uuid"``
        2. By VM name, if UUID matching is unavailable

    Args:
        process_configs: Parsed process configuration dictionaries extracted
            from the launch command file.
        mm_api: Connected minimega API instance.

    Returns:
        A mapping from VM name to minimega ID.

    Raises:
        RuntimeError: If a VM cannot be matched, or if multiple running VMs
            match the same expected VM.
        KeyError: If a process config is missing a required ``"vm_name"`` key.
    """
    running_vms = mm_api.mm_vms()

    by_uuid: dict[str, dict[str, str]] = {}
    by_name: dict[str, dict[str, str]] = {}

    for vm_name, vm_info in running_vms.items():
        by_name[vm_name] = vm_info
        vm_uuid = vm_info.get("uuid")
        if vm_uuid:
            by_uuid[vm_uuid] = vm_info

    vm_name_to_mm_id: dict[str, str] = {}

    for process_config in process_configs:
        expected_vm_name = str(process_config["vm_name"])
        expected_vm_uuid = process_config.get("vm_uuid")

        matched_vm: dict[str, str] | None = None

        if isinstance(expected_vm_uuid, str) and expected_vm_uuid:
            matched_vm = by_uuid.get(expected_vm_uuid)

        if matched_vm is None:
            matched_vm = by_name.get(expected_vm_name)

        if matched_vm is None:
            raise RuntimeError(
                "Could not match launched VM from process config "
                f"vm_name={expected_vm_name!r}, vm_uuid={expected_vm_uuid!r}"
            )

        mm_id = matched_vm.get("id")
        if not isinstance(mm_id, str) or not mm_id:
            raise RuntimeError(
                f"Matched VM for {expected_vm_name!r} is missing a valid minimega ID"
            )

        vm_name_to_mm_id[expected_vm_name] = mm_id

    return vm_name_to_mm_id


def rewrite_launch_cmds_file(
    input_path: Path,
    output_path: Path,
    vm_name_to_mm_id: Mapping[str, str],
    mm_base: str,
) -> None:
    """Rewrite a launch command file with updated socket paths.

    Each non-empty line is parsed, the embedded JSON configuration is updated,
    and the modified command is written to the output file.

    Args:
        input_path: Path to the existing launch command file.
        output_path: Path where the updated file will be written.
        vm_name_to_mm_id: Mapping from VM name to new minimega ID.
        mm_base: Base directory for minimega socket paths.

    Raises:
        ValueError: If any line does not match the expected command format.
        json.JSONDecodeError: If embedded JSON cannot be parsed.
        KeyError: If required JSON fields or VM mappings are missing.
        OSError: If reading or writing the files fails.
    """
    with input_path.open("r", encoding="utf-8") as infile, output_path.open("w", encoding="utf-8") as outfile:
        for line in infile:
            if not line.strip():
                outfile.write(line)
                continue

            updated_line = update_launch_command_line(
                line=line,
                vm_name_to_mm_id=vm_name_to_mm_id,
                mm_base=mm_base,
            )
            outfile.write(updated_line + "\n")


def rebuild_launch_cmds_file_with_current_mm_ids(
    input_path: Path,
    output_path: Path,
    mm_api: minimegaAPI,
) -> dict[str, str]:
    """Rebuild a launch command file using current minimega VM IDs.

    This function:
        1. Reads and parses the existing launch command file
        2. Queries minimega for currently running VMs
        3. Builds a VM name to minimega ID mapping
        4. Rewrites the launch command file with updated socket paths

    Args:
        input_path: Path to the existing launch command file.
        output_path: Path where the updated file will be written.
        mm_api: Connected minimega API instance.

    Returns:
        The mapping from VM name to minimega ID used for the rewrite.

    Raises:
        ValueError: If any line does not match the expected command format.
        json.JSONDecodeError: If embedded JSON cannot be parsed.
        KeyError: If required JSON fields are missing.
        RuntimeError: If VMs cannot be matched to currently running minimega VMs.
        OSError: If file IO fails.
    """
    with input_path.open("r", encoding="utf-8") as infile:
        process_configs = iter_process_configs(infile)

    vm_name_to_mm_id = build_vm_name_to_mm_id_map(
        process_configs=process_configs,
        mm_api=mm_api,
    )

    rewrite_launch_cmds_file(
        input_path=input_path,
        output_path=output_path,
        vm_name_to_mm_id=vm_name_to_mm_id,
        mm_base=mm_api.mm_base,
    )

    return vm_name_to_mm_id


def _run_minimega_script(script_path: Path, description: str) -> None:
    """
    Run a minimega script.

    Raises:
        subprocess.CalledProcessError
        FileNotFoundError
        PermissionError
        OSError
    """
    minimega_bin_path = os.path.join(
        fw_config["minimega"]["install_dir"], "bin", "minimega"
    )

    result = subprocess.run(
        [
            minimega_bin_path,
            f"-base={fw_config['minimega']['base_dir']}",
            "-e",
            "read",
            str(script_path),
        ],
        check=True,
    )

    console.print(f"[green]{description}: ret={result.returncode}.[/green]")


def _restore_from_directory(source_dir: Path) -> int:
    """
    Restore VM mappings, experiment files, schedules, and start scripts
    from a validated directory structure.
    """
    try:
        exp_dir = _validate_restore_directory(source_dir)
    except FileNotFoundError as exc:
        console.print(f"[red]Invalid restore directory: {exc}[/red]")
        return 1
    except NotADirectoryError as exc:
        console.print(f"[red]Invalid restore directory: {exc}[/red]")
        return 1
    except ValueError as exc:
        console.print(f"[red]Invalid restore directory layout: {exc}[/red]")
        return 1
    except OSError as exc:
        console.print(f"[red]Unable to inspect restore directory [cyan]{source_dir}[/cyan]: {exc}[/red]")
        return 1

    experiment_name = exp_dir.name

    try:
        saved_exp = FileStore("saved")
        vm_mapping = VMMapping()
        schedule_db = ScheduleDb()
    except OSError as exc:
        console.print(f"[red]OS error initializing resources: {exc}[/red]")
        return 1
    except ValueError as exc:
        console.print(f"[red]Configuration error initializing resources: {exc}[/red]")
        return 1

    mapping_file = source_dir / "vm_mapping.json"
    try:
        _restore_vm_mapping(mapping_file, vm_mapping)
    except FileNotFoundError as exc:
        console.print(f"[red]Required mapping file not found: {exc}[/red]")
        return 1
    except PermissionError as exc:
        console.print(f"[red]Permission denied reading mapping file: {exc}[/red]")
        return 1
    except json.JSONDecodeError as exc:
        console.print(f"[red]Invalid JSON in mapping file [cyan]{mapping_file}[/cyan]: {exc}[/red]")
        return 1
    except OSError as exc:
        console.print(f"[red]Error restoring VM mapping state: {exc}[/red]")
        return 1

    saved_exp_path = Path(saved_exp.get_file_path(experiment_name))
    try:
        _restore_experiment_files(exp_dir, saved_exp_path)
    except FileExistsError:
        console.print(
            f"[yellow]The VM State/HDD files for experiment [cyan]{experiment_name}[/cyan] "
            f"already exist at [cyan]{saved_exp_path}[/cyan]. Using in-place files instead.[/yellow]"
        )
    except FileNotFoundError as exc:
        console.print(f"[red]Experiment files not found: {exc}[/red]")
        return 1
    except PermissionError as exc:
        console.print(f"[red]Permission denied restoring experiment files: {exc}[/red]")
        return 1
    except OSError as exc:
        console.print(f"[red]Error restoring VM State/HDD directory: {exc}[/red]")
        return 1

    schedule_dir = source_dir / "schedules"
    try:
        _restore_schedule_files(schedule_dir, schedule_db)
    except PermissionError as exc:
        console.print(f"[red]Permission denied restoring schedule files: {exc}[/red]")
        return 1
    except OSError as exc:
        console.print(f"[red]Error restoring schedule files: {exc}[/red]")
        return 1

    try:
        _run_minimega_script(saved_exp_path / "launch.mm", "Started saved VMs")
    except FileNotFoundError as exc:
        console.print(f"[red]minimega or VM launch script not found: {exc}[/red]")
        return 1
    except PermissionError as exc:
        console.print(f"[red]Permission denied starting VMs: {exc}[/red]")
        return 1
    except subprocess.CalledProcessError as exc:
        console.print(f"[red]Error starting VMs: {exc}[/red]")
        return 1
    except OSError as exc:
        console.print(f"[red]OS error starting VMs: {exc}[/red]")
        return 1
    
    try:
        _restore_experiment_time(source_dir / "experiment_time.json")
    except FileNotFoundError as exc:
        console.print(f"[red]Experiment time file not found: {exc}[/red]")
        return 1
    except ValueError as exc:
        console.print(f"[red]Invalid experiment time file: {exc}[/red]")
        return 1

    try:
        mm_api = minimegaAPI()
        launch_cmd_path = Path(source_dir / "launch_cmds.mm")
        launch_cmd_updated_path = Path(source_dir / "launch_cmds_updated.mm")
        vm_name_to_mm_id = rebuild_launch_cmds_file_with_current_mm_ids(
            input_path=launch_cmd_path,
            output_path=launch_cmd_updated_path,
            mm_api=mm_api,
        )
        console.print(f"[green]Mapped VM names to minimega IDs: {vm_name_to_mm_id}[/green]")
        _run_minimega_script(launch_cmd_updated_path, "Started VM Resource scripts")
    except FileNotFoundError as exc:
        console.print(f"[red]minimega or launch script not found: {exc}[/red]")
        return 1
    except PermissionError as exc:
        console.print(f"[red]Permission denied running VM resource scripts: {exc}[/red]")
        return 1
    except subprocess.CalledProcessError as exc:
        console.print(f"[red]Error starting VM resource scripts: {exc}[/red]")
        return 1
    except OSError as exc:
        console.print(f"[red]OS error running VM resource scripts: {exc}[/red]")
        return 1

    return 0


def load_vm_state(input_path: str) -> int:
    """
    Load VM state and schedules from either:
      - a tar archive, or
      - a directory containing the extracted restore content
    """
    source_path = Path(input_path).resolve()

    if not source_path.exists():
        console.print(f"[red]Error: Path [cyan]{source_path}[/cyan] does not exist.[/red]")
        return 1

    if source_path.is_file():
        if not _is_supported_archive(source_path):
            console.print(
                f"[red]Error: File [cyan]{source_path}[/cyan] is not a supported archive. "
                f"Expected one of: .tar.gz, .tgz, .tar[/red]"
            )
            return 1

        try:
            with tempfile.TemporaryDirectory() as temp_dir:
                temp_path = Path(temp_dir)
                _extract_archive(source_path, temp_path)
                return _restore_from_directory(temp_path)
        except tarfile.ReadError as exc:
            console.print(
                f"[red]Error: File [cyan]{source_path}[/cyan] is not a readable tar archive: {exc}[/red]"
            )
            return 1
        except tarfile.CompressionError as exc:
            console.print(
                f"[red]Error: Unsupported or invalid archive compression for [cyan]{source_path}[/cyan]: {exc}[/red]"
            )
            return 1
        except PermissionError as exc:
            console.print(f"[red]Permission denied accessing archive [cyan]{source_path}[/cyan]: {exc}[/red]")
            return 1
        except OSError as exc:
            console.print(f"[red]OS error while processing archive [cyan]{source_path}[/cyan]: {exc}[/red]")
            return 1

    if source_path.is_dir():
        return _restore_from_directory(source_path)

    console.print(
        f"[red]Error: Path [cyan]{source_path}[/cyan] is neither a regular file nor a directory.[/red]"
    )
    return 1


if __name__ == "__main__":
    parser = argparse.ArgumentParser(
        description="Load VM state and schedule files from either an archive or a directory."
    )
    parser.add_argument(
        "source",
        type=str,
        help="Path to the compressed backup file or extracted experiment directory.",
    )
    args = parser.parse_args()
    sys.exit(load_vm_state(args.source))
